<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gate_Access_Management.ViewModels.Pages.Tenants"
             x:Class="Gate_Access_Management.Views.Pages.Tenants.TenantHostView"
             x:DataType="vm:TenantHostViewModel">

    <Grid RowDefinitions="75,*" Margin="20">

        <!-- HEADER BAR -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,2*,*"
              VerticalAlignment="Center"
              Margin="0,0,0,16">

            <!-- LEFT SLOT -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <Button Classes="BackButton"
                        Command="{Binding ShowListCommand}"
                        IsVisible="{Binding ShowBackButton}" />
            </StackPanel>

            <!-- CENTER TITLE -->
            <TextBlock Grid.Column="1"
                       Text="{Binding CurrentView.PageTitle}"
                       FontSize="48"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!-- RIGHT SLOT -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Classes="ActionButton"
                        Content="Create Tenant"
                        Command="{Binding ShowCreateCommand}"
                        IsVisible="{Binding ShowCreateButton}" />
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Border Grid.Row="1"
                Background="#141414"
                BorderBrush="#E6E6E6"
                BorderThickness="2"
                CornerRadius="14"
                Padding="24">
            <ContentControl Content="{Binding CurrentView}" />
        </Border>
    </Grid>
</UserControl>