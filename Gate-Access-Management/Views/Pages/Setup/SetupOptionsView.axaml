<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Gate_Access_Management.ViewModels.Pages.Setup"
             x:Class="Gate_Access_Management.Views.Pages.Setup.SetupOptionsView"
             x:DataType="vm:SetupOptionsViewModel">

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center"
          RowDefinitions="Auto,Auto"
          ColumnDefinitions="Auto,Auto"
          RowSpacing="20"
          ColumnSpacing="20">

        <Button Grid.Row="0"
                Grid.Column="0"
                Classes="OptionButton"
                Content="Access Schedules"
                Command="{Binding ShowAccessSchedulesCommand}" />

        <Button Grid.Row="0"
                Grid.Column="1"
                Classes="OptionButton"
                Content="Unit Types"
                Command="{Binding ShowUnitTypesCommand}" />

        <Button Grid.Row="1"
                Grid.Column="0"
                Classes="OptionButton"
                Content="Settings"
                Command="{Binding ShowSettingsCommand}" />

        <Button Grid.Row="1"
                Grid.Column="1"
                Classes="OptionButton"
                Content="Placeholder" />
    </Grid>
</UserControl>