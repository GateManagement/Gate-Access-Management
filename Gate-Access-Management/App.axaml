<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Gate_Access_Management.App"
             xmlns:local="using:Gate_Access_Management"
             RequestedThemeVariant="Dark">

    <!-- View Mapping -->
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <!-- Global Resources -->
    <Application.Resources>
    </Application.Resources>

    <!-- Global Styles -->
    <Application.Styles>
        <FluentTheme />

        <!-- Shell Button -->
        <Style Selector="ToggleButton.ShellToggleButton">
            <Setter Property="Width" Value="250" />
            <Setter Property="Height" Value="90" />
            <Setter Property="FontSize" Value="32" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#2F2F2F" />
            <Setter Property="BorderBrush" Value="#2A2A2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="ToggleButton.ShellToggleButton:pointerover">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="BorderBrush" Value="#444444" />
        </Style>

        <Style Selector="ToggleButton.ShellToggleButton:pressed">
            <Setter Property="Background" Value="#242424" />
        </Style>

        <Style Selector="ToggleButton.ShellToggleButton:checked">
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="BorderBrush" Value="#1976D2" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Large Option Button -->
        <Style Selector="Button.OptionButton">
            <Setter Property="Width" Value="320" />
            <Setter Property="Height" Value="110" />
            <Setter Property="FontSize" Value="34" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#141414" />
            <Setter Property="BorderBrush" Value="#E6E6E6" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.OptionButton:pointerover">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.OptionButton:pressed">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="BorderBrush" Value="#1976D2" />
        </Style>

        <!-- Medium Action Button -->
        <Style Selector="Button.ActionButton">
            <Setter Property="Width" Value="210" />
            <Setter Property="Height" Value="70" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#141414" />
            <Setter Property="BorderBrush" Value="#E6E6E6" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.ActionButton:pointerover">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.ActionButton:pressed">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="BorderBrush" Value="#1976D2" />
        </Style>

        <!-- Back Button -->
        <Style Selector="Button.BackButton">
            <Setter Property="Content" Value="← Back" />
            <Setter Property="Width" Value="132" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#141414" />
            <Setter Property="BorderBrush" Value="#E6E6E6" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0,12,0" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.BackButton:pointerover">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.BackButton:pressed">
            <Setter Property="Background" Value="#101010" />
            <Setter Property="BorderBrush" Value="#1976D2" />
        </Style>
    </Application.Styles>
</Application>